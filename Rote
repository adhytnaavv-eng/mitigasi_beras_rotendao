  {id:'rs', name:'Rote Selatan',   short:'R.Selatan',  base:620, growth:.009,tadah:.75,ir:.13,ht:.12,color:'#993556',

   coords:[[-10.90,123.15],[-10.88,123.25],[-10.92,123.30],[-10.98,123.25],[-11.00,123.14],[-10.96,123.08],[-10.90,123.15]]},

  {id:'ll', name:'Landu Leko',     short:'L.Leko',     base:310, growth:.008,tadah:.78,ir:.12,ht:.10,color:'#0f6e56',

   coords:[[-10.88,123.45],[-10.85,123.52],[-10.90,123.58],[-10.95,123.54],[-10.98,123.44],[-10.92,123.38],[-10.88,123.45]]},

  {id:'nn', name:'Ndao Nuse',      short:'Ndao Nuse',  base:240, growth:.007,tadah:.80,ir:.10,ht:.10,color:'#5f5e5a',

   coords:[[-10.95,122.84],[-10.92,122.90],[-10.96,122.96],[-11.02,122.92],[-11.04,122.83],[-10.98,122.78],[-10.95,122.84]]},

