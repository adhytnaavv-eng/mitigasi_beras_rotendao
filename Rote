const tC=['#3b6d11','#1d9e75','#639922','#ba7517','#378add'];

const tL=['Total Pulau','Rote Tengah','Lobalain','Rote Timur','R.B. Daya'];

document.getElementById('trendLegend').innerHTML=tL.map((l,i)=>`<span class="lg-item"><span class="lg-dot" style="background:${tC[i]}"></span>${l}</span>`).join('');



new Chart(document.getElementById('trendChart'),{

  type:'line',

  data:{

    labels:YEARS,

    datasets:[

      {label:'Total',data:YEARS.map(y=>totalForYear(y)),borderColor:'#3b6d11',backgroundColor:'rgba(59,109,17,.06)',fill:true,tension:.4,borderWidth:2.5,pointRadius:0},

      ...KEC.slice(0,4).map((k,i)=>({label:k.name,data:YEARS.map(y=>haForYear(k,y)),borderColor:tC[i+1],fill:false,tension:.4,borderWidth:1.5,pointRadius:0,borderDash:i>0?[4,3]:[]}))

    ]

  },

  options:{responsive:true,maintainAspectRatio:false,

    plugins:{legend:{display:false},tooltip:{callbacks:{label:c=>c.dataset.label+': '+fmt(c.parsed.y)+' ha'}}},

    scales:{x:{grid:{color:'rgba(128,128,128,.06)'},ticks:{font:{size:9},maxTicksLimit:8}},y:{grid:{color:'rgba(128,128,128,.06)'},ticks:{font:{size:9},callback:v=>(v/1000).toFixed(0)+'k ha'}}}}

});



function copyLink(){

  navigator.clipboard.writeText(window.location.href).then(()=>{

    const b=document.querySelector('.sbtn.p');b.textContent='✓ Disalin!';

    setTimeout(()=>b.innerHTML='⊕ Salin Link',2000);

  });

}



update(2024);

