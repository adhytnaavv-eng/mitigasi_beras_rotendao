const YEARS = Array.from({length:26},(_,i)=>2000+i);

let selId = null, currentYear = 2024, playing = false, playInt = null;

const fmt = n => n.toLocaleString('id-ID');



function haForYear(k,y){

  const t=y-2000, seed=k.base*.0031;

  return Math.round(k.base*Math.pow(1+k.growth,t)+Math.sin(t*.7+seed*Math.PI)*18+Math.cos(t*.3+seed)*9);

}

function totalForYear(y){return KEC.reduce((s,k)=>s+haForYear(k,y),0)}



/* ─── LEAFLET MAP ─── */

const map = L.map('leaflet-map',{zoomControl:true,scrollWheelZoom:true,dragging:true});

L.tileLayer('https://{s}.basemaps.cartocdn.com/light_nolabels/{z}/{x}/{y}{r}.png',{

  attribution:'© OpenStreetMap © CARTO',maxZoom:13,opacity:.45

}).addTo(map);



const tooltip = L.DomUtil.create('div','kec-tooltip');

document.getElementById('leaflet-map').appendChild(tooltip);

tooltip.style.display='none';



let layers = {};

let geojsonLayer;



function getColor(ha, maxHa){

  const t = ha/maxHa;

  const stops=[

    [0.00,'#eaf3de'],[0.15,'#c0dd97'],[0.30,'#97c459'],

    [0.50,'#639922'],[0.70,'#3b6d11'],[1.00,'#1e3a07']

  ];

  for(let i=1;i<stops.length;i++){

    if(t<=stops[i][0]){

      const a=stops[i-1],b=stops[i];

      const p=(t-a[0])/(b[0]-a[0]);

      return lerpColor(a[1],b[1],p);

    }

  }

  return stops[stops.length-1][1];

}



function lerpColor(a,b,t){

  const pa=parseInt(a.slice(1),16),pb=parseInt(b.slice(1),16);

  const ar=(pa>>16)&255,ag=(pa>>8)&255,ab=pa&255;

  const br=(pb>>16)&255,bg=(pb>>8)&255,bb=pb&255;

  const r=Math.round(ar+(br-ar)*t),g=Math.round(ag+(bg-ag)*t),bv=Math.round(ab+(bb-ab)*t);

  return '#'+(r<<16|g<<8|bv).toString(16).padStart(6,'0');

}



function buildGeoJSON(year){

  const vals = KEC.map(k=>haForYear(k,year));

  const maxHa = Math.max(...vals);

  return {

    type:'FeatureCollection',

    features: KEC.map((k,i)=>({

      type:'Feature',

      properties:{id:k.id,name:k.name,ha:vals[i],maxHa,pct:(vals[i]/totalForYear(year)*100).toFixed(1)},

      geometry:{type:'Polygon',coordinates:[k.coords.map(c=>[c[1],c[0]])]}

    }))

  };

}



function styleFeature(f){

  const isSel = f.properties.id===selId;

  return {

    fillColor: getColor(f.properties.ha, f.properties.maxHa),

    fillOpacity: isSel ? 1 : 0.75,

    color: isSel ? '#1e3a07' : '#fff',

    weight: isSel ? 2.5 : 1,

  };

}



function onEach(feature, layer){

  layer.on({

    mouseover(e){

      const p=e.target.feature.properties;

      layer.setStyle({fillOpacity:0.92,weight:2,color:'#1e3a07'});

      tooltip.innerHTML=`<strong>${p.name}</strong><div class="t-ha">${fmt(p.ha)} ha</div><div class="t-pct">${p.pct}% dari total sawah</div>`;

      tooltip.style.display='block';

    },

    mousemove(e){

      const rect=document.getElementById('leaflet-map').getBoundingClientRect();

      const x=e.originalEvent.clientX-rect.left, y=e.originalEvent.clientY-rect.top;

      tooltip.style.left=(x+14)+'px'; tooltip.style.top=(y-10)+'px';

    },

    mouseout(){

      geojsonLayer.resetStyle(layer);

      geojsonLayer.setStyle(styleFeature);

      tooltip.style.display='none';

    },

    click(){

      const id=feature.properties.id;

      selId = selId===id ? null : id;

      selectKec(selId);

    }

  });

}



function renderMap(year){

  const gj = buildGeoJSON(year);

  if(geojsonLayer) map.removeLayer(geojsonLayer);

  geojsonLayer = L.geoJSON(gj,{style:styleFeature,onEachFeature:onEach}).addTo(map);

  if(!layers._fitted){ map.fitBounds(geojsonLayer.getBounds(),{padding:[16,16]}); layers._fitted=true; }

}



/* ─── UI UPDATE ─── */

function update(year){

  currentYear=year;

  const data=KEC.map(k=>({...k,ha:haForYear(k,year)})).sort((a,b)=>b.ha-a.ha);

  const total=data.reduce((s,d)=>s+d.ha,0);

  const t2000=totalForYear(2000), diff=total-t2000;

  const cov=(total/97854*100).toFixed(1);

  const pctVs2000=(total/t2000*100-100).toFixed(1);



  document.getElementById('m-total').textContent=fmt(total);

  document.getElementById('m-tsub').textContent=(pctVs2000>=0?'+':'')+pctVs2000+'% vs 2000';

  const mc=document.getElementById('m-chg');

  mc.textContent=(diff>=0?'+':'')+fmt(diff);

  mc.className='m-val '+(diff>=0?'up':'dn');

  document.getElementById('m-top').textContent=data[0].short;

  document.getElementById('m-tsub2').textContent=fmt(data[0].ha)+' ha';

  document.getElementById('m-cov').textContent=cov+'%';



  // Bar rows

  document.getElementById('barRows').innerHTML=data.map(d=>{

    const pct=(d.ha/data[0].ha*100).toFixed(1);

    return `<div class="bar-row">

      <span class="bar-lbl">${d.name}</span>

      <div class="bar-track"><div class="bar-fill" style="width:${pct}%;background:${d.color}"></div></div>

      <span class="bar-num">${fmt(d.ha)} ha</span>

    </div>`;

  }).join('');



  // Rank list

  document.getElementById('rankList').innerHTML=data.map((d,i)=>{

    const pct=(d.ha/total*100).toFixed(1);

    return `<div class="rank-item ${selId===d.id?'active':''}" onclick="selectKec('${d.id}')">

      <span class="rank-num">${i+1}</span>

      <div class="rank-info">

        <div class="rank-name">${d.name}</div>

        <div class="rank-bar-track"><div class="rank-bar-fill" style="width:${Math.min(pct*4.5,100)}%;background:${d.color}"></div></div>

      </div>

      <div class="rank-ha">${fmt(d.ha)} ha<br><span style="font-size:9px;color:var(--text3)">${pct}%</span></div>

    </div>`;

  }).join('');



  // Map

  renderMap(year);



  // Detail panel

  if(selId) updateDetail(year,total);

}



function selectKec(id){

  selId=(selId===id)?null:id;

  const panel=document.getElementById('detailPanel');

  if(!selId){panel.classList.remove('show');}

  else{updateDetail(currentYear,totalForYear(currentYear));panel.classList.add('show');}

  update(currentYear);

}



function clearSel(){selId=null;document.getElementById('detailPanel').classList.remove('show');update(currentYear)}



function updateDetail(year,total){

  const k=KEC.find(x=>x.id===selId); if(!k)return;

  const ha=haForYear(k,year), ha0=haForYear(k,2000), diff=ha-ha0;

  document.getElementById('dName').textContent=k.name;

  document.getElementById('d-ha').textContent=fmt(ha)+' ha';

  document.getElementById('d-th').textContent=fmt(Math.round(ha*k.tadah))+' ha';

  document.getElementById('d-ir').textContent=fmt(Math.round(ha*k.ir))+' ha';

  document.getElementById('d-ht').textContent=fmt(Math.round(ha*k.ht))+' ha';

  document.getElementById('d-pct').textContent=(ha/total*100).toFixed(1)+'%';

  document.getElementById('d-chg').textContent=(diff>=0?'+':'')+fmt(diff)+' ha';

}



/* ─── SLIDER ─── */

const slider=document.getElementById('yearSlider');

const yrDisp=document.getElementById('yearDisplay');

function setSliderBg(s){s.style.setProperty('--pct',((s.value-s.min)/(s.max-s.min)*100).toFixed(1)+'%')}

slider.addEventListener('input',()=>{yrDisp.textContent=slider.value;setSliderBg(slider);update(+slider.value)});

setSliderBg(slider);



/* ─── PLAY ─── */

const playBtn=document.getElementById('playBtn');

playBtn.addEventListener('click',()=>{

  if(playing){clearInterval(playInt);playing=false;playBtn.textContent='▶';}

  else{

    playing=true;playBtn.textContent='⏸';

    let y=+slider.value; if(y>=2025)y=2000;

    playInt=setInterval(()=>{

      y=y>=2025?2000:y+1;

      slider.value=y;yrDisp.textContent=y;setSliderBg(slider);update(y);

      if(y===2025){clearInterval(playInt);playing=false;playBtn.textContent='▶';}

    },420);

  }

});



